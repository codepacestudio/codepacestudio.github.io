    "Wymień 3 sytuacje, w których czułeś totalne zażenowanie zachowaniem partnera.",
    "Wymień 3 najseksowniejsze stroje na Halloween.",
    "Wymień 3 powody, by zrobić komuś malinkę w widocznym miejscu.",
    "Wymień 3 rzeczy, które robisz, gdy randka okazuje się totalną nudą.",
    "Wymień 3 najdziwniejsze miejsca, w których uprawiałeś autostop erotyczny.",
    "Wymień 3 powody, dla których ta gra zniszczy dzisiaj jakiś związek.",
    "Wymień 3 rzeczy, o których pomyślisz, gdy zobaczysz ten kod za rok.",
    "Wymień 3 powody, dla których natychmiast powinieneś wziąć się do właściwej roboty."
];

    ];

    let players = [];
    let targetScore = 10;
    let baseTime = 5;
    
    let currentPool = [...questions];
    let timerInterval = null;
    let audioCtx = null;

    function initAudio() {
        if (!audioCtx) {
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }
    }

    function playBeep(freq, type, duration, vol) {
        if (!audioCtx) return;
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = type;
        osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
        gain.gain.setValueAtTime(vol, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + duration);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + duration);
    }

    function playTick() { playBeep(800, 'sine', 0.1, 0.5); }
    function playBuzzer() { playBeep(150, 'sawtooth', 0.8, 1); }

    function updateSettings() {
        baseTime = parseInt(document.getElementById('time-setting').value);
        targetScore = parseInt(document.getElementById('pts-setting').value);
        document.getElementById('time-val').innerText = baseTime;
        document.getElementById('pts-val').innerText = targetScore;
    }

    function addPlayer() {
        const input = document.getElementById('player-input');
        const name = input.value.trim();
        if (name && !players.find(p => p.name === name)) {
            players.push({ name: name, score: 0 });
            input.value = '';
            renderPlayerList();
        }
    }

    function renderPlayerList() {
        const list = document.getElementById('player-list');
        list.innerHTML = '';
        players.forEach(p => {
            const span = document.createElement('span');
            span.className = 'player-tag';
            span.innerText = p.name;
            list.appendChild(span);
        });
    }

    function initGame() {
        if (players.length < 2) {
            alert("Dodaj minimum 2 graczy!");
            return;
        }
        initAudio();
        document.getElementById('screen-setup').classList.add('hidden');
        document.getElementById('screen-game').classList.remove('hidden');
        updateScoreBoard();
        document.getElementById('timer-text').innerText = baseTime;
    }

    function updateScoreBoard() {
        const board = document.getElementById('in-game-scores');
        const awardGrid = document.getElementById('award-buttons');
        board.innerHTML = '';
        awardGrid.innerHTML = '';

        players.forEach((p, index) => {
            board.innerHTML += `<div class="score-item"><div class="score-name">${p.name}</div><div class="score-pts">${p.score}</div></div>`;
            awardGrid.innerHTML += `<button class="btn btn-player" onclick="awardPoint(${index})">${p.name}</button>`;
        });
    }

    function drawQuestion() {
        if (currentPool.length === 0) currentPool = [...questions];
        
        document.getElementById('award-section').style.display = 'none';
        document.getElementById('btn-draw').classList.add('hidden');
        document.getElementById('btn-start').classList.remove('hidden');
        
        const rIndex = Math.floor(Math.random() * currentPool.length);
        const q = currentPool.splice(rIndex, 1)[0];
        document.getElementById('question-box').innerText = q;
        
        document.getElementById('timer-text').innerText = baseTime;
        const bar = document.getElementById('progress-bar');
        bar.style.transition = 'none';
        bar.style.transform = 'scaleX(1)';
    }

    function startTimer() {
        document.getElementById('btn-start').classList.add('hidden');
        initAudio();
        
        let timeLeft = baseTime;
        document.getElementById('timer-text').innerText = timeLeft;
        
        const bar = document.getElementById('progress-bar');
        bar.style.transform = 'scaleX(1)';
        bar.offsetHeight; 
        bar.style.transition = `transform ${baseTime}s linear`;
        bar.style.transform = 'scaleX(0)';

        clearInterval(timerInterval);
        playTick();

        timerInterval = setInterval(() => {
            timeLeft--;
            if (timeLeft > 0) {
                document.getElementById('timer-text').innerText = timeLeft;
                playTick();
            } else {
                clearInterval(timerInterval);
                document.getElementById('timer-text').innerText = "CZAS!";
                playBuzzer();
                showAwardSection();
            }
        }, 1000);
    }

    function showAwardSection() {
        document.getElementById('award-section').style.display = 'block';
    }

    function awardPoint(playerIndex) {
        players[playerIndex].score++;
        updateScoreBoard();
        checkWinCondition();
    }

    function nobodyScored() {
        checkWinCondition();
    }

    function checkWinCondition() {
        document.getElementById('award-section').style.display = 'none';
        
        const winner = players.find(p => p.score >= targetScore);
        if (winner) {
            document.getElementById('screen-game').classList.add('hidden');
            document.getElementById('screen-winner').classList.remove('hidden');
            document.getElementById('winner-text').innerText = winner.name + " Wygrywa!";
        } else {
            document.getElementById('btn-draw').classList.remove('hidden');
        }
    }
</script>
</body>
</html>
