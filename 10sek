        input[type="range"] { width: 100%; accent-color: #ff2a5f; }
        .val-display { text-align: center; font-size: 1.2rem; font-weight: bold; margin-top: 10px; color: #fff; }
        
        .btn { width: 100%; padding: 15px; border: none; border-radius: 10px; font-size: 1.1rem; font-weight: bold; text-transform: uppercase; cursor: pointer; transition: 0.2s; color: #fff; margin-bottom: 10px; }
        .btn:active { transform: scale(0.95); }
        .btn-primary { background: linear-gradient(135deg, #7928ca, #ff2a5f); }
        .btn-secondary { background: #374151; }
        .btn-player { background: #059669; font-size: 0.9rem; padding: 10px; }
        
        #player-list { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px; }
        .player-tag { background: #ff2a5f; padding: 5px 12px; border-radius: 20px; font-size: 0.9rem; font-weight: bold; }

        /* GRA */
        #timer-text { font-size: 6rem; font-weight: 900; text-align: center; color: #ff2a5f; text-shadow: 0 0 20px rgba(255, 42, 95, 0.5); margin: 20px 0; }
        .progress-bg { width: 100%; height: 10px; background: #22123b; border-radius: 5px; overflow: hidden; margin-bottom: 30px; }
        #progress-bar { width: 100%; height: 100%; background: linear-gradient(90deg, #ff2a5f, #7928ca); transform-origin: left; }
        
        #question-box { flex: 1; display: flex; justify-content: center; align-items: center; text-align: center; min-height: 150px; font-size: 1.8rem; font-weight: 600; padding: 20px; background: rgba(255,255,255,0.03); border-radius: 15px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 20px; }
        
        .score-board { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
        .score-item { background: rgba(0,0,0,0.5); padding: 10px; border-radius: 8px; text-align: center; border: 1px solid #7928ca; }
        .score-item.active { border-color: #ff2a5f; background: rgba(255, 42, 95, 0.2); }
        .score-name { font-size: 0.9rem; color: #a78bfa; }
        .score-pts { font-size: 1.5rem; font-weight: bold; }

        #award-section { display: none; background: #111; padding: 15px; border-radius: 10px; border: 1px solid #333; margin-bottom: 20px; }
        #award-section h3 { text-align: center; font-size: 1rem; color: #a78bfa; margin-bottom: 10px; }
        .award-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

        /* WYNIKI */
        #winner-text { font-size: 3rem; text-align: center; color: #10b981; margin: 40px 0; font-weight: bold; }
